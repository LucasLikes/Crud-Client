# ============================================================
#  Lume API — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to version control.
# ============================================================

# ─── Server ─────────────────────────────────────────────────
SERVER_PORT=8080

# ─── JWT ────────────────────────────────────────────────────
# Minimum 256-bit (32-char) random hex string for HS256
# Generate one: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# Token lifetimes in milliseconds
JWT_ACCESS_EXPIRATION_MS=900000       # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000   # 7 days

# ─── Database ───────────────────────────────────────────────
# H2 in-memory (default / local dev) — leave these commented out
# SPRING_DATASOURCE_URL=jdbc:h2:mem:lumedb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=
# SPRING_DATASOURCE_DRIVER=org.h2.Driver

# PostgreSQL (production example)
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/lumedb
# SPRING_DATASOURCE_USERNAME=lume
# SPRING_DATASOURCE_PASSWORD=strongpassword
# SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
# JPA_DDL_AUTO=validate

# ─── H2 Console ─────────────────────────────────────────────
# Disable in production
H2_CONSOLE_ENABLED=true

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── JPA ────────────────────────────────────────────────────
JPA_SHOW_SQL=false
JPA_DDL_AUTO=update
